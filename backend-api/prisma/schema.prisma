generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hospital {
  id             String          @id @default(cuid())
  name           String          @unique
  address        String?
  description    String?
  email          String?
  phone          String?
  administrators Administrator[]
  doctors        Doctor[]
}

model Patient {
  id               String           @id @default(cuid())
  email            String           @unique
  passwordHash     String
  name             String
  avatar           String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  address          String?
  emergencyContact String?
  phone            String?
  accessRequests   AccessRequest[]
  activityLogs     ActivityLog[]
  alerts           Alert[]
  appointments     Appointment[]
  diagnoses        Diagnosis[]
  doctorNotes      DoctorNote[]
  documents        Document[]
  medicalHistory   MedicalHistory[]
  records          MedicalRecord[]
  prescriptions    Prescription[]
  vitals           VitalReading[]
}

model Doctor {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String
  avatar         String?
  hospitalId     String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  phone          String?
  specialty      String?
  status         String          @default("active")
  accessRequests AccessRequest[]
  alerts         Alert[]
  hospital       Hospital        @relation(fields: [hospitalId], references: [id])
}

model Administrator {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatar       String?
  hospitalId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  phone        String?
  hospital     Hospital @relation(fields: [hospitalId], references: [id])
}

model Otp {
  id         String    @id @default(cuid())
  email      String
  purpose    String
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  userRole  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model VitalReading {
  id          String   @id @default(cuid())
  patientId   String
  date        DateTime @default(now())
  temperature Float?
  systolic    Float?
  diastolic   Float?
  heartRate   Float?
  weight      Float?
  symptoms    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id])
}

model MedicalRecord {
  id        String   @id @default(cuid())
  patientId String
  type      String
  title     String
  content   String?
  fileUrl   String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model AccessRequest {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  reason    String
  priority  String   @default("NORMAL")
  status    String   @default("PENDING")
  otp       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  patientId String
  actor     String
  action    String
  resource  String
  ip        String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model Document {
  id        String   @id @default(cuid())
  patientId String
  name      String
  type      String
  url       String?
  fileId    String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model Alert {
  id          String   @id @default(cuid())
  doctorId    String
  patientId   String
  title       String
  description String
  severity    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  patient     Patient  @relation(fields: [patientId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  audience    String
  title       String
  description String
  type        String
  read        Boolean  @default(false)
  link        String?
  createdAt   DateTime @default(now())

  @@index([audience, read])
}

model Appointment {
  id        String   @id @default(cuid())
  patientId String
  specialty String
  provider  String
  datetime  DateTime
  location  String
  encrypted Boolean  @default(true)
  status    String   @default("SCHEDULED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model MedicalHistory {
  id        String   @id @default(cuid())
  patientId String
  date      DateTime
  event     String
  facility  String
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model Diagnosis {
  id        String   @id @default(cuid())
  patientId String
  code      String
  name      String
  status    String
  since     String?
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

model Prescription {
  id          String   @id @default(cuid())
  patientId   String
  drug        String
  dose        String
  sig         String
  refills     Int
  expires     DateTime
  createdAt   DateTime @default(now())
  description String   @default("")
  title       String   @default("")
  patient     Patient  @relation(fields: [patientId], references: [id])
}

model DoctorNote {
  id        String   @id @default(cuid())
  patientId String
  author    String
  date      DateTime
  note      String
  encrypted Boolean  @default(true)
  createdAt DateTime @default(now())
  patient   Patient  @relation(fields: [patientId], references: [id])
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}
